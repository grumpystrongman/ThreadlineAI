<Window
    x:Class="Threadline.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ThreadlineAI Sidecar">
  <Grid Padding="14" RowDefinitions="Auto,Auto,Auto,*,Auto,Auto" RowSpacing="10" MaxWidth="560">
    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
      <StackPanel Spacing="2">
        <TextBlock Text="ThreadlineAI" FontSize="24" FontWeight="SemiBold" />
        <TextBlock Text="Context follows your active work." Opacity="0.72" />
        <TextBlock x:Name="ServiceStatusText" Text="Service: unknown" Opacity="0.72" />
      </StackPanel>
      <ComboBox x:Name="ProviderBox" Grid.Column="1" Width="128" SelectedIndex="5" VerticalAlignment="Top">
        <ComboBoxItem Content="OpenAI" />
        <ComboBoxItem Content="Claude" />
        <ComboBoxItem Content="Gemini" />
        <ComboBoxItem Content="DeepSeek" />
        <ComboBoxItem Content="OpenRouter" />
        <ComboBoxItem Content="Local" />
      </ComboBox>
    </Grid>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
      <Button Content="New Chat" Click="NewChat_Click" />
      <Button Content="Clear Context" Click="ClearSharedContext_Click" />
      <Button Content="Use Session" Click="UseActiveSession_Click" />
      <Button Content="Check" Click="CheckService_Click" />
    </StackPanel>

    <Border Grid.Row="2" BorderThickness="1" CornerRadius="10" Padding="10">
      <StackPanel Spacing="8">
        <TextBlock Text="Current Thread" FontSize="15" FontWeight="SemiBold" />
        <TextBlock x:Name="SessionText" Text="No active Threadline session." TextWrapping="Wrap" />
        <TextBlock Text="Current Target" FontSize="15" FontWeight="SemiBold" Margin="0,6,0,0" />
        <TextBlock x:Name="CurrentWindowText" Text="No target window." TextWrapping="Wrap" MaxLines="6" />
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="Refresh Apps" Click="RefreshOpenWindows_Click" />
          <Button Content="Use Selected" Click="UseSelectedTarget_Click" />
        </StackPanel>
        <ListView x:Name="OpenWindowsList" Height="180" SelectionMode="Single" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="3" RowDefinitions="*,Auto" RowSpacing="8">
      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <TextBox x:Name="ChatTranscript" Text="Start or use a session, pick an app/tab, then ask Threadline about that target." TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" />
      </ScrollViewer>
      <ListView x:Name="TimelineList" Grid.Row="1" Height="72" />
    </Grid>

    <TextBox x:Name="QuestionBox" Grid.Row="4" PlaceholderText="Ask about the selected app, tab, document, or session..." AcceptsReturn="True" MinHeight="86" TextWrapping="Wrap" />

    <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="8">
      <Button Content="Ask" Click="Ask_Click" />
      <Button Content="Propose Insert" Click="ProposeInsert_Click" />
      <Button Content="Done" Click="CompleteLastAction_Click" />
      <Button Content="Clear Transcript" Click="ClearTranscript_Click" />
      <Button Content="Start Session" Click="StartSession_Click" />
    </StackPanel>
  </Grid>
</Window>
