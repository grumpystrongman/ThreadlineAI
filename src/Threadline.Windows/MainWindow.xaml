<Window
    x:Class="Threadline.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ThreadlineAI Companion">
  <Grid Padding="16" RowDefinitions="Auto,Auto,*" RowSpacing="12">
    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
      <TextBlock Text="ThreadlineAI" FontSize="24" FontWeight="SemiBold" />
      <TextBlock x:Name="ServiceStatusText" Text="Service: unknown" VerticalAlignment="Center" />
      <Button Content="Check Service" Click="CheckService_Click" />
      <Button Content="Start Session" Click="StartSession_Click" />
      <Button Content="Use Active Session" Click="UseActiveSession_Click" />
      <ComboBox x:Name="ProviderBox" Width="150" SelectedIndex="5">
        <ComboBoxItem Content="OpenAI" />
        <ComboBoxItem Content="Claude" />
        <ComboBoxItem Content="Gemini" />
        <ComboBoxItem Content="DeepSeek" />
        <ComboBoxItem Content="OpenRouter" />
        <ComboBoxItem Content="Local" />
      </ComboBox>
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="2*,3*" ColumnSpacing="16">
      <StackPanel Spacing="8">
        <TextBlock Text="Session" FontSize="16" FontWeight="SemiBold" />
        <TextBlock x:Name="SessionText" Text="No active Threadline session." TextWrapping="Wrap" />
      </StackPanel>
      <StackPanel Grid.Column="1" Spacing="8">
        <TextBlock Text="Attached Window" FontSize="16" FontWeight="SemiBold" />
        <TextBlock x:Name="CurrentWindowText" Text="No attached window." TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="Refresh Foreground" Click="RefreshWindow_Click" />
          <Button Content="Attach Window" Click="AttachWindow_Click" />
          <Button Content="Preview Window Context" Click="PreviewWindow_Click" />
          <Button Content="Store Window Context" Click="StoreWindow_Click" />
          <Button Content="Capture Native UI in 3s" Click="PreviewNativeUi_Click" />
        </StackPanel>
      </StackPanel>
    </Grid>

    <Grid Grid.Row="2" ColumnDefinitions="2*,3*" ColumnSpacing="16">
      <StackPanel Spacing="8">
        <TextBlock Text="Timeline" FontSize="18" FontWeight="SemiBold" />
        <ListView x:Name="TimelineList" MinHeight="440" />
      </StackPanel>
      <Grid Grid.Column="1" RowDefinitions="*,Auto,Auto" RowSpacing="10">
        <ScrollViewer>
          <TextBlock x:Name="ChatTranscript" Text="Start or use a session, attach a window, then ask Threadline about the active session." TextWrapping="Wrap" />
        </ScrollViewer>
        <TextBox x:Name="QuestionBox" Grid.Row="1" PlaceholderText="Ask about this session or attached window..." AcceptsReturn="True" MinHeight="72" TextWrapping="Wrap" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
          <Button Content="Ask / Compose Prompt" Click="Ask_Click" />
          <Button Content="Propose Insert Action" Click="ProposeInsert_Click" />
          <Button Content="Mark Last Action Complete" Click="CompleteLastAction_Click" />
          <Button Content="Clear Transcript" Click="ClearTranscript_Click" />
        </StackPanel>
      </Grid>
    </Grid>
  </Grid>
</Window>
