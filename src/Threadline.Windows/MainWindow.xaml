<Window
    x:Class="Threadline.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ThreadlineAI Sidecar">
  <Grid x:Name="RootShell" ColumnDefinitions="Auto,*" Background="Transparent">
    <Border x:Name="EdgeHandlePanel"
            Width="44"
            Visibility="Collapsed"
            Opacity="0.90"
            CornerRadius="14"
            BorderThickness="1"
            BorderBrush="#D7E2F3"
            Background="#F8FBFF"
            Padding="6"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            PointerEntered="ExpandSidecarFromHandle"
            PointerPressed="ExpandSidecarFromHandle">
      <Grid RowDefinitions="*,Auto,*">
        <StackPanel Grid.Row="1" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
          <TextBlock Text="◉" FontSize="18" Foreground="#2563EB" HorizontalAlignment="Center" />
          <TextBlock Text="AI" FontSize="12" FontWeight="SemiBold" Foreground="#111827" HorizontalAlignment="Center" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid x:Name="ChatShellPanel"
          Grid.Column="1"
          Background="#F8FAFF"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
      <Grid RowDefinitions="Auto,*,Auto,Auto"
            RowSpacing="8"
            Padding="12"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#DCE6F5" BorderThickness="1" CornerRadius="18" Padding="12,10">
          <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Border Width="30" Height="30" CornerRadius="15" Background="#EEF5FF" BorderBrush="#C8DBFF" BorderThickness="1">
                  <TextBlock Text="◉" FontSize="18" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="ThreadlineAI" FontSize="18" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                <Button x:Name="AttachSidecarButton"
                        Content="Dock"
                        Click="ToggleAttachSidecar_Click"
                        FontSize="11"
                        MinWidth="64"
                        Padding="8,4"
                        Foreground="#1D4ED8"
                        Background="#EFF6FF"
                        BorderBrush="#BFDBFE" />
                <Button Content="×"
                        Click="CollapseSidecarToHandle_Click"
                        FontSize="16"
                        MinWidth="36"
                        Padding="8,2"
                        Foreground="#111827"
                        Background="#F8FAFF"
                        BorderBrush="#DCE6F5" />
              </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" Spacing="2">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBlock x:Name="WorkThreadStatusText"
                           Text="Work Thread: ready"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           TextWrapping="WrapWholeWords"
                           MaxLines="2" />
                <TextBlock Grid.Column="1" Text="✎" FontSize="12" Foreground="#6B7280" VerticalAlignment="Center" />
              </Grid>
              <TextBox x:Name="WorkThreadTitleBox"
                       PlaceholderText="Name this work thread..."
                       FontSize="11"
                       TextWrapping="NoWrap"
                       BorderThickness="0"
                       Background="Transparent"
                       Foreground="#4B5563"
                       Height="1"
                       Opacity="0" />
              <TextBlock x:Name="SidecarAttachmentText"
                         Text="Sidecar: attached to active work."
                         TextWrapping="WrapWholeWords"
                         MaxLines="2"
                         FontSize="11"
                         Foreground="#6B7280" />
            </StackPanel>

            <Grid Grid.Row="2" ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
              <Button Content="Sessions" Click="ToggleSessionManagerPanel_Click" FontSize="11" Padding="6,4" Foreground="#111827" Background="#F8FAFF" BorderBrush="#DCE6F5" />
              <Button Grid.Column="1" Content="Settings" Click="ToggleProviderSettingsPanel_Click" FontSize="11" Padding="6,4" Foreground="#111827" Background="#F8FAFF" BorderBrush="#DCE6F5" />
              <Button Grid.Column="2" Content="Tools" Click="ToggleDiagnosticsTargetPickerPanel_Click" FontSize="11" Padding="6,4" Foreground="#111827" Background="#F8FAFF" BorderBrush="#DCE6F5" />
              <Button Grid.Column="3" Content="Hide" Click="CollapseSidecarToHandle_Click" FontSize="11" Padding="6,4" Foreground="#111827" Background="#F8FAFF" BorderBrush="#DCE6F5" />
            </Grid>
          </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Enabled"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalScrollMode="Disabled"
                      ZoomMode="Disabled">
          <StackPanel Spacing="8">
            <Border x:Name="SessionBindingPanel"
                    Background="#FFF7ED"
                    BorderBrush="#FED7AA"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="10"
                    Visibility="Collapsed">
              <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                <TextBlock x:Name="SessionBindingStatusText"
                           Text="Window session: no pending connection. Click AI on another window to choose how to connect it."
                           TextWrapping="WrapWholeWords"
                           MaxLines="3"
                           FontSize="11"
                           Foreground="#7C2D12" />
                <Grid Grid.Row="1" ColumnDefinitions="*,*,Auto" ColumnSpacing="6">
                  <Button Content="Connect"
                          Click="ConnectPendingTargetToCurrentSession_Click"
                          FontSize="11"
                          Padding="6,4"
                          Foreground="#7C2D12"
                          Background="#FFEDD5"
                          BorderBrush="#FDBA74" />
                  <Button Grid.Column="1"
                          Content="New session"
                          Click="StartNewSessionForPendingTarget_Click"
                          FontSize="11"
                          Padding="6,4"
                          Foreground="#7C2D12"
                          Background="#FFEDD5"
                          BorderBrush="#FDBA74" />
                  <Button Grid.Column="2"
                          Content="Detach"
                          Click="DetachPendingTarget_Click"
                          FontSize="11"
                          Padding="6,4"
                          Foreground="#7C2D12"
                          Background="#FFEDD5"
                          BorderBrush="#FDBA74" />
                </Grid>
              </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
              <Border Background="#FFFFFF" BorderBrush="#DCE6F5" BorderThickness="1" CornerRadius="14" Padding="10">
                <StackPanel Spacing="4">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Work Thread" FontSize="11" FontWeight="SemiBold" Foreground="#111827" />
                    <Border CornerRadius="8" Background="#ECFDF3" Padding="6,1">
                      <TextBlock Text="● Active" FontSize="10" Foreground="#16A34A" />
                    </Border>
                  </StackPanel>
                  <TextBlock Text="Resumed 2m ago" FontSize="11" Foreground="#6B7280" />
                </StackPanel>
              </Border>

              <Border x:Name="CurrentContextPanel" Grid.Column="1" Background="#FFFFFF" BorderBrush="#DCE6F5" BorderThickness="1" CornerRadius="14" Padding="10">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                  <Border x:Name="ContextStatusPill" Width="28" Height="28" CornerRadius="14" Background="#EEF5FF">
                    <TextBlock x:Name="ContextStatusText" Text="◉" Foreground="#2563EB" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="Connected context" FontSize="11" FontWeight="SemiBold" Foreground="#111827" />
                    <TextBlock x:Name="CurrentContextText"
                               Text="12 sources • High confidence"
                               TextWrapping="WrapWholeWords"
                               MaxLines="2"
                               FontSize="11"
                               Foreground="#6B7280" />
                  </StackPanel>
                </Grid>
              </Border>
            </Grid>

            <Border Background="#FFFFFF" BorderBrush="#DCE6F5" BorderThickness="1" CornerRadius="16" Padding="10">
              <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Spacing="2">
                    <TextBlock Text="Context Receipt" FontSize="12" FontWeight="SemiBold" Foreground="#111827" />
                    <TextBlock Text="Shows what Threadline used, skipped, and trusted." FontSize="11" Foreground="#6B7280" TextWrapping="WrapWholeWords" MaxLines="2" />
                  </StackPanel>
                  <Button Grid.Column="1" Content="Details" FontSize="11" Padding="6,4" Foreground="#1D4ED8" Background="#EFF6FF" BorderBrush="#BFDBFE" />
                </Grid>
                <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="6">
                  <Border Background="#F8FAFF" BorderBrush="#E5EDF8" BorderThickness="1" CornerRadius="12" Padding="8,6">
                    <StackPanel>
                      <TextBlock Text="12" FontWeight="SemiBold" Foreground="#111827" />
                      <TextBlock Text="Used" FontSize="11" Foreground="#6B7280" />
                    </StackPanel>
                  </Border>
                  <Border Grid.Column="1" Background="#F8FAFF" BorderBrush="#E5EDF8" BorderThickness="1" CornerRadius="12" Padding="8,6">
                    <StackPanel>
                      <TextBlock Text="3" FontWeight="SemiBold" Foreground="#111827" />
                      <TextBlock Text="Skipped" FontSize="11" Foreground="#6B7280" />
                    </StackPanel>
                  </Border>
                  <Border Grid.Column="2" Background="#F8FAFF" BorderBrush="#E5EDF8" BorderThickness="1" CornerRadius="12" Padding="8,6">
                    <StackPanel>
                      <TextBlock Text="High" FontWeight="SemiBold" Foreground="#111827" />
                      <TextBlock Text="Trust" FontSize="11" Foreground="#6B7280" />
                    </StackPanel>
                  </Border>
                </Grid>
              </Grid>
            </Border>

            <Border Background="#FFFFFF" BorderBrush="#DCE6F5" BorderThickness="1" CornerRadius="18" Padding="0" MinHeight="130">
              <ScrollViewer x:Name="TranscriptScrollViewer"
                            VerticalScrollBarVisibility="Auto"
                            VerticalScrollMode="Enabled"
                            HorizontalScrollBarVisibility="Disabled"
                            HorizontalScrollMode="Disabled"
                            ZoomMode="Disabled"
                            Padding="10,8,10,12">
                <ItemsControl x:Name="TranscriptList">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="#FFFFFF"
                              BorderBrush="#E5EDF8"
                              BorderThickness="1"
                              CornerRadius="14"
                              Padding="12"
                              Margin="0,5,0,5"
                              HorizontalAlignment="Stretch">
                        <StackPanel Spacing="6">
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding Speaker}" FontSize="12" FontWeight="SemiBold" Foreground="#111827" />
                            <TextBlock Grid.Column="1" Text="{Binding TimestampDisplay}" FontSize="11" Foreground="#6B7280" />
                          </Grid>
                          <TextBlock Text="{Binding Message}"
                                     TextWrapping="WrapWholeWords"
                                     IsTextSelectionEnabled="True"
                                     Foreground="#111827" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#DCE6F5" BorderThickness="1" CornerRadius="16" Padding="10">
          <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="7">
            <TextBox x:Name="QuestionBox"
                     PlaceholderText="Ask anything about this work thread..."
                     AcceptsReturn="True"
                     Height="58"
                     MaxHeight="64"
                     TextWrapping="Wrap"
                     BorderThickness="0"
                     Background="Transparent" />
            <Grid Grid.Row="1" ColumnDefinitions="Auto,* ,Auto" ColumnSpacing="8">
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="📎" FontSize="13" Foreground="#4B5563" />
                <TextBlock Text="@" FontSize="13" Foreground="#4B5563" />
                <TextBlock Text="▣" FontSize="13" Foreground="#4B5563" />
                <TextBlock Text="🌐" FontSize="13" Foreground="#4B5563" />
              </StackPanel>
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                <Button Content="Copy" Click="CopyLastAnswer_Click" FontSize="11" Padding="8,4" Foreground="#111827" Background="#F8FAFF" BorderBrush="#DCE6F5" />
                <Button Content="Ask" Click="TrustedAsk_Click" FontSize="11" Padding="14,4" Foreground="#FFFFFF" Background="#2563EB" BorderBrush="#1D4ED8" />
              </StackPanel>
            </Grid>
            <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled" ZoomMode="Disabled">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Content="Summary" Click="CreateSummaryArtifact_Click" FontSize="11" Padding="8,4" Foreground="#111827" Background="#F8FAFF" BorderBrush="#DCE6F5" />
                <Button Content="Handoff" Click="CreateHandoffArtifact_Click" FontSize="11" Padding="8,4" Foreground="#111827" Background="#F8FAFF" BorderBrush="#DCE6F5" />
                <Button Content="Decisions" Click="CreateDecisionsArtifact_Click" FontSize="11" Padding="8,4" Foreground="#111827" Background="#F8FAFF" BorderBrush="#DCE6F5" />
                <Button Content="Risks" Click="CreateRisksArtifact_Click" FontSize="11" Padding="8,4" Foreground="#111827" Background="#F8FAFF" BorderBrush="#DCE6F5" />
                <Button Content="Next Actions" Click="CreateNextActionsArtifact_Click" FontSize="11" Padding="8,4" Foreground="#111827" Background="#F8FAFF" BorderBrush="#DCE6F5" />
                <Button Content="Clear" Click="ClearTranscript_Click" FontSize="11" Padding="8,4" Foreground="#111827" Background="#F8FAFF" BorderBrush="#DCE6F5" />
              </StackPanel>
            </ScrollViewer>
          </Grid>
        </Border>

        <Border Grid.Row="3" Background="#FFFFFF" BorderBrush="#DCE6F5" BorderThickness="1" CornerRadius="16" Padding="10,8">
          <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Privacy &amp; Trust" FontSize="12" FontWeight="SemiBold" Foreground="#111827" />
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5">
                <TextBlock Text="●" Foreground="#16A34A" />
                <TextBlock Text="Protected" FontSize="11" FontWeight="SemiBold" Foreground="#16A34A" />
              </StackPanel>
            </Grid>
            <Grid Grid.Row="1" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="2">
              <CheckBox x:Name="AllowProviderContextToggle" Content="Provider context" IsChecked="True" FontSize="11" Foreground="#374151" />
              <CheckBox x:Name="SaveWorkThreadMemoryToggle" Grid.Column="1" Content="Memory" IsChecked="True" FontSize="11" Foreground="#374151" />
              <CheckBox x:Name="ShowContextReceiptsToggle" Grid.Row="1" Content="Receipts" IsChecked="True" FontSize="11" Foreground="#374151" />
              <TextBlock x:Name="TrustControlStatusText"
                         Grid.Row="1"
                         Grid.Column="1"
                         Text="Sources are governed before provider send."
                         TextWrapping="WrapWholeWords"
                         MaxLines="2"
                         FontSize="10"
                         Foreground="#6B7280" />
            </Grid>
            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" BorderBrush="#E5EDF8" BorderThickness="0,1,0,0" Padding="0,6,0,0">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="● Memory on" FontSize="10" Foreground="#16A34A" />
                <TextBlock Text="Resumed" FontSize="10" Foreground="#6B7280" />
              </StackPanel>
              <TextBlock Grid.Column="1" Text="✓ Auto-saved" FontSize="10" Foreground="#16A34A" />
            </Grid>
          </Grid>
        </Border>

        <ListView x:Name="TimelineList" Grid.Row="3" Height="1" Visibility="Collapsed" />
      </Grid>

      <Border x:Name="ShellOverlayPanel"
              Width="390"
              MaxWidth="430"
              HorizontalAlignment="Right"
              VerticalAlignment="Stretch"
              Background="#FFFFFF"
              BorderBrush="#DCE6F5"
              BorderThickness="1"
              CornerRadius="18"
              Padding="10"
              Visibility="Collapsed">
        <Grid RowDefinitions="Auto,*" RowSpacing="8">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBlock x:Name="ShellOverlayTitleText" Text="Panel" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="Close" Click="CloseShellOverlayPanel_Click" FontSize="12" Padding="8,4" />
          </Grid>
          <Grid Grid.Row="1">
            <Border x:Name="WorkThreadSessionManagerPanel" BorderThickness="1" BorderBrush="#E5EDF8" CornerRadius="12" Padding="10" Visibility="Collapsed">
              <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <StackPanel>
                    <TextBlock Text="Sessions" FontSize="14" FontWeight="SemiBold" />
                    <TextBlock x:Name="WorkThreadListStatusText" Text="Refresh to see recent Work Threads." TextWrapping="WrapWholeWords" MaxLines="2" FontSize="11" Opacity="0.72" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Top">
                    <Button Content="Refresh" Click="RefreshWorkThreads_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Resume" Click="ResumeSelectedWorkThread_Click" FontSize="12" Padding="8,4" />
                  </StackPanel>
                </Grid>
                <ListView x:Name="WorkThreadList" Grid.Row="1" Height="160" SelectionMode="Single" SelectionChanged="WorkThreadList_SelectionChanged" FontSize="11" HorizontalContentAlignment="Stretch" />
                <TextBox x:Name="SessionManagerTitleBox" Grid.Row="2" PlaceholderText="Rename selected or active Work Thread..." FontSize="11" TextWrapping="NoWrap" />
                <StackPanel Grid.Row="3" Spacing="6">
                  <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                    <Button Content="New Thread" Click="NewWorkThread_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Resume Active" Click="ResumeWorkThread_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Close Active" Click="CloseWorkThread_Click" FontSize="12" Padding="8,4" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                    <Button Content="Rename Selected" Click="RenameSelectedWorkThread_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Tie Window" Click="TieCurrentWindowToSelectedThread_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Detach Window" Click="DetachCurrentWindowFromWorkThread_Click" FontSize="12" Padding="8,4" />
                  </StackPanel>
                </StackPanel>
                <TextBlock x:Name="WorkThreadSelectedText" Grid.Row="4" Text="Selected: none" TextWrapping="WrapWholeWords" MaxLines="2" FontSize="11" Opacity="0.72" />
              </Grid>
            </Border>

            <Border x:Name="ProviderSettingsPanel" BorderThickness="1" BorderBrush="#E5EDF8" CornerRadius="12" Padding="10" Visibility="Collapsed">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <StackPanel>
                    <TextBlock Text="Provider Settings" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="Provider configuration stays here. Privacy and trust controls are always visible in the footer." TextWrapping="WrapWholeWords" FontSize="11" Opacity="0.72" />
                  </StackPanel>
                  <Button Grid.Column="1" Content="Close" Click="CloseProviderSettingsPanel_Click" FontSize="12" Padding="8,4" VerticalAlignment="Top" />
                </Grid>
                <Grid Grid.Row="1" RowDefinitions="Auto,Auto" RowSpacing="8">
                  <TextBlock x:Name="ProviderSettingsStatusText" Text="Provider settings not saved yet." TextWrapping="WrapWholeWords" FontSize="11" Opacity="0.82" />
                  <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="Use Defaults" Click="UseProviderDefaults_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Save Provider" Click="SaveProviderSettings_Click" FontSize="12" Padding="10,4" />
                  </StackPanel>
                </Grid>
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Chat provider" FontWeight="SemiBold" Margin="0,4,0,0" />
                    <ComboBox x:Name="ProviderBox" SelectedIndex="0" SelectionChanged="ProviderBox_SelectionChanged" HorizontalAlignment="Stretch">
                      <ComboBoxItem Content="OpenAI" />
                      <ComboBoxItem Content="Claude" />
                      <ComboBoxItem Content="Gemini" />
                      <ComboBoxItem Content="DeepSeek" />
                      <ComboBoxItem Content="OpenRouter" />
                      <ComboBoxItem Content="Local" />
                    </ComboBox>
                    <TextBlock Text="Settings provider" FontWeight="SemiBold" Margin="0,4,0,0" />
                    <ComboBox x:Name="SettingsProviderBox" SelectedIndex="0" SelectionChanged="SettingsProviderBox_SelectionChanged" HorizontalAlignment="Stretch">
                      <ComboBoxItem Content="OpenAI" />
                      <ComboBoxItem Content="Claude" />
                      <ComboBoxItem Content="Gemini" />
                      <ComboBoxItem Content="DeepSeek" />
                      <ComboBoxItem Content="OpenRouter" />
                      <ComboBoxItem Content="Local" />
                    </ComboBox>
                    <TextBox x:Name="ProviderBaseUrlBox" Header="Base URL" PlaceholderText="https://api.openai.com/v1/" TextWrapping="NoWrap" />
                    <TextBox x:Name="ProviderModelBox" Header="Default model" PlaceholderText="gpt-4.1-mini" TextWrapping="NoWrap" />
                    <PasswordBox x:Name="ProviderApiKeyBox" Header="API key" PlaceholderText="Stored through Threadline local secret storage" />
                    <TextBlock x:Name="ProviderSettingsHintText" Text="For OpenAI, paste your API key once, then click Save Provider. The key is stored by the local Threadline service." TextWrapping="WrapWholeWords" FontSize="11" Opacity="0.74" />
                  </StackPanel>
                </ScrollViewer>
              </Grid>
            </Border>

            <Border x:Name="DiagnosticsTargetPickerPanel" BorderThickness="1" BorderBrush="#E5EDF8" CornerRadius="12" Padding="10" Visibility="Collapsed">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="8">
                  <TextBlock Text="Diagnostics / Target Picker" FontSize="16" FontWeight="SemiBold" />
                  <TextBlock x:Name="ServiceStatusText" Text="Service: unknown" TextWrapping="WrapWholeWords" FontSize="11" Opacity="0.72" />
                  <TextBlock x:Name="SessionText" Text="No active Threadline session." TextWrapping="WrapWholeWords" FontSize="11" Opacity="0.72" />
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="New Chat" Click="NewChat_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Use Session" Click="UseActiveSession_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Start Session" Click="StartSession_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Check" Click="CheckService_Click" FontSize="12" Padding="8,4" />
                  </StackPanel>
                  <TextBlock Text="Target picker" FontWeight="SemiBold" Margin="0,6,0,0" />
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="Refresh" Click="RefreshOpenWindows_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Use" Click="UseSelectedTarget_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Follow / Lock" Click="ToggleFollowLock_Click" FontSize="12" Padding="8,4" />
                  </StackPanel>
                  <ListView x:Name="OpenWindowsList" Height="190" SelectionMode="Single" FontSize="11" HorizontalContentAlignment="Stretch" />
                  <Border x:Name="DiagnosticsPanel" BorderThickness="1" BorderBrush="#E5EDF8" CornerRadius="8" Padding="6" Visibility="Collapsed">
                    <TextBlock x:Name="DiagnosticsText" Text="No diagnostics yet." TextWrapping="WrapWholeWords" FontSize="10" Opacity="0.82" />
                  </Border>
                  <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                    <Button Content="Diagnostics" Click="ToggleDiagnostics_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Clear Context" Click="ClearSharedContext_Click" FontSize="12" Padding="8,4" />
                  </StackPanel>
                </StackPanel>
              </ScrollViewer>
            </Border>
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>