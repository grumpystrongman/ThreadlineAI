<Window
    x:Class="Threadline.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ThreadlineAI Sidecar">
  <Grid Padding="12" RowDefinitions="Auto,*,Auto,Auto" RowSpacing="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
      <StackPanel Spacing="4">
        <TextBlock Text="ThreadlineAI" FontSize="22" FontWeight="SemiBold" />
        <TextBlock Text="Context follows your active work." Opacity="0.72" />
        <TextBlock x:Name="ServiceStatusText" Text="Service: unknown" Opacity="0.72" />
        <TextBlock x:Name="SessionText" Text="No active Threadline session." TextWrapping="Wrap" MaxLines="2" Opacity="0.72" />
        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
          <Button Content="New" Click="NewChat_Click" FontSize="12" Padding="8,4" />
          <Button Content="Use Session" Click="UseActiveSession_Click" FontSize="12" Padding="8,4" />
          <Button Content="Check" Click="CheckService_Click" FontSize="12" Padding="8,4" />
          <Button Content="Start" Click="StartSession_Click" FontSize="12" Padding="8,4" />
          <Button Content="Clear Context" Click="ClearSharedContext_Click" FontSize="12" Padding="8,4" />
        </StackPanel>
      </StackPanel>
      <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Top">
        <ComboBox x:Name="ProviderBox" Width="146" SelectedIndex="0" SelectionChanged="ProviderBox_SelectionChanged">
          <ComboBoxItem Content="OpenAI" />
          <ComboBoxItem Content="Claude" />
          <ComboBoxItem Content="Gemini" />
          <ComboBoxItem Content="DeepSeek" />
          <ComboBoxItem Content="OpenRouter" />
          <ComboBoxItem Content="Local" />
        </ComboBox>
        <Button Content="Settings" FontSize="12" Padding="10,4" HorizontalAlignment="Stretch">
          <Button.Flyout>
            <Flyout>
              <ScrollViewer Width="380" MaxHeight="540" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="8" Padding="4">
                  <TextBlock Text="Provider Settings" FontSize="18" FontWeight="SemiBold" />
                  <TextBlock Text="Save provider credentials and model settings here instead of running setup commands." TextWrapping="WrapWholeWords" Opacity="0.78" />

                  <TextBlock Text="Provider" FontWeight="SemiBold" Margin="0,6,0,0" />
                  <ComboBox x:Name="SettingsProviderBox" SelectedIndex="0" SelectionChanged="SettingsProviderBox_SelectionChanged" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="OpenAI" />
                    <ComboBoxItem Content="Claude" />
                    <ComboBoxItem Content="Gemini" />
                    <ComboBoxItem Content="DeepSeek" />
                    <ComboBoxItem Content="OpenRouter" />
                    <ComboBoxItem Content="Local" />
                  </ComboBox>

                  <TextBlock Text="Base URL" FontWeight="SemiBold" Margin="0,6,0,0" />
                  <TextBox x:Name="ProviderBaseUrlBox" PlaceholderText="https://api.openai.com/v1/" TextWrapping="NoWrap" />

                  <TextBlock Text="Default model" FontWeight="SemiBold" Margin="0,6,0,0" />
                  <TextBox x:Name="ProviderModelBox" PlaceholderText="gpt-4.1-mini" TextWrapping="NoWrap" />

                  <TextBlock Text="API key" FontWeight="SemiBold" Margin="0,6,0,0" />
                  <PasswordBox x:Name="ProviderApiKeyBox" PlaceholderText="Stored through Threadline local secret storage" />

                  <TextBlock x:Name="ProviderSettingsHintText"
                             Text="For OpenAI, paste your API key once, then click Save. The key is stored by the local Threadline service."
                             TextWrapping="WrapWholeWords"
                             FontSize="11"
                             Opacity="0.74" />

                  <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Use Defaults" Click="UseProviderDefaults_Click" FontSize="12" Padding="10,4" />
                    <Button Content="Save Provider" Click="SaveProviderSettings_Click" FontSize="12" Padding="10,4" />
                  </StackPanel>

                  <TextBlock x:Name="ProviderSettingsStatusText"
                             Text="Provider settings not saved yet."
                             TextWrapping="WrapWholeWords"
                             FontSize="11"
                             Opacity="0.78" />
                </StackPanel>
              </ScrollViewer>
            </Flyout>
          </Button.Flyout>
        </Button>
      </StackPanel>
    </Grid>

    <Grid Grid.Row="1" ColumnDefinitions="320,*" ColumnSpacing="10" MinHeight="480">
      <Border Grid.Column="0" BorderThickness="1" CornerRadius="8" Padding="8">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="6">
          <TextBlock Text="Current Target" FontSize="14" FontWeight="SemiBold" />
          <TextBlock x:Name="CurrentWindowText" Grid.Row="1" Text="No target window." TextWrapping="Wrap" MaxLines="8" FontSize="12" Opacity="0.86" />

          <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4">
            <Button Content="Refresh" Click="RefreshOpenWindows_Click" FontSize="11" Padding="6,3" />
            <Button Content="Use" Click="UseSelectedTarget_Click" FontSize="11" Padding="6,3" />
            <Button Content="Follow / Lock" Click="ToggleFollowLock_Click" FontSize="11" Padding="6,3" />
            <Button Content="Diagnostics" Click="ToggleDiagnostics_Click" FontSize="11" Padding="6,3" />
          </StackPanel>

          <TextBlock Grid.Row="3" Text="Open Apps and Tabs" FontSize="12" FontWeight="SemiBold" Opacity="0.74" />
          <ListView x:Name="OpenWindowsList"
                    Grid.Row="4"
                    SelectionMode="Single"
                    FontSize="11"
                    HorizontalContentAlignment="Stretch"
                    VerticalAlignment="Stretch">
            <ListView.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}"
                           FontSize="11"
                           TextWrapping="WrapWholeWords"
                           MaxLines="3"
                           Opacity="0.86"
                           Margin="0,2" />
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </Grid>
      </Border>

      <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" RowSpacing="6" MinHeight="480">
        <Border x:Name="CurrentContextPanel" BorderThickness="1" CornerRadius="8" Padding="8">
          <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
              <TextBlock Text="Current Context" FontSize="13" FontWeight="SemiBold" Opacity="0.82" />
              <Border x:Name="ContextStatusPill"
                      Grid.Column="1"
                      BorderThickness="1"
                      CornerRadius="10"
                      Padding="8,2"
                      VerticalAlignment="Center">
                <TextBlock x:Name="ContextStatusText"
                           Text="No context"
                           FontSize="11"
                           Opacity="0.82" />
              </Border>
            </Grid>

            <TextBlock x:Name="CurrentContextText"
                       Grid.Row="1"
                       Text="No resolved context yet. Select a target and click Use."
                       TextWrapping="WrapWholeWords"
                       MaxLines="4"
                       FontSize="11"
                       Opacity="0.86" />

            <Border x:Name="DiagnosticsPanel" Grid.Row="2" BorderThickness="1" CornerRadius="6" Padding="6" Visibility="Collapsed">
              <TextBlock x:Name="DiagnosticsText"
                         Text="No diagnostics yet."
                         TextWrapping="WrapWholeWords"
                         FontSize="10"
                         Opacity="0.82" />
            </Border>
          </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
          <TextBlock Text="Conversation" FontSize="16" FontWeight="SemiBold" />
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
            <Button Content="Top" Click="JumpTranscriptTop_Click" FontSize="12" Padding="8,4" />
            <Button Content="Bottom" Click="JumpTranscriptBottom_Click" FontSize="12" Padding="8,4" />
            <Button Content="Copy Conversation" Click="CopyConversation_Click" FontSize="12" Padding="8,4" />
            <Button Content="Copy Last Answer" Click="CopyLastAnswer_Click" FontSize="12" Padding="8,4" />
          </StackPanel>
        </Grid>

        <Border Grid.Row="2" BorderThickness="1" CornerRadius="10" Padding="0">
          <ScrollViewer x:Name="TranscriptScrollViewer"
                        VerticalScrollBarVisibility="Auto"
                        VerticalScrollMode="Enabled"
                        HorizontalScrollBarVisibility="Disabled"
                        HorizontalScrollMode="Disabled"
                        ZoomMode="Disabled"
                        Padding="8,6,8,12">
            <ItemsControl x:Name="TranscriptList">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderThickness="1"
                          CornerRadius="10"
                          Padding="10"
                          Margin="0,4,0,4"
                          HorizontalAlignment="Stretch">
                    <StackPanel Spacing="4">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding Speaker}"
                                   FontWeight="SemiBold"
                                   Opacity="0.90" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding TimestampDisplay}"
                                   FontSize="11"
                                   Opacity="0.58" />
                      </Grid>
                      <TextBlock Text="{Binding Message}"
                                 TextWrapping="WrapWholeWords"
                                 IsTextSelectionEnabled="True" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>
      </Grid>
    </Grid>

    <Border Grid.Row="2" BorderThickness="1" CornerRadius="10" Padding="8">
      <Grid RowDefinitions="*,Auto" RowSpacing="6">
        <TextBox x:Name="QuestionBox"
                 PlaceholderText="Ask about the selected app, tab, document, or session..."
                 AcceptsReturn="True"
                 MinHeight="76"
                 TextWrapping="Wrap"
                 BorderThickness="0" />
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
          <Button Content="Ask" Click="Ask_Click" FontSize="12" Padding="10,4" />
          <Button Content="Propose" Click="ProposeInsert_Click" FontSize="12" Padding="10,4" />
          <Button Content="Done" Click="CompleteLastAction_Click" FontSize="12" Padding="10,4" />
          <Button Content="Clear" Click="ClearTranscript_Click" FontSize="12" Padding="10,4" />
        </StackPanel>
      </Grid>
    </Border>

    <ListView x:Name="TimelineList" Grid.Row="3" Height="34" FontSize="11" />
  </Grid>
</Window>