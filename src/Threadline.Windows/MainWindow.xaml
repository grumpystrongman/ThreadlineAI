<Window
    x:Class="Threadline.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ThreadlineAI Sidecar">
  <Grid x:Name="RootShell" ColumnDefinitions="Auto,*" Background="Transparent">
    <Border x:Name="EdgeHandlePanel"
            Width="44"
            Visibility="Collapsed"
            Opacity="0.82"
            CornerRadius="12"
            BorderThickness="1"
            Padding="6"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            PointerEntered="ExpandSidecarFromHandle"
            PointerPressed="ExpandSidecarFromHandle">
      <Grid RowDefinitions="*,Auto,*">
        <StackPanel Grid.Row="1" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
          <TextBlock Text="✦" FontSize="18" HorizontalAlignment="Center" />
          <TextBlock Text="AI" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid x:Name="ChatShellPanel"
          Grid.Column="1"
          Padding="12"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
      <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto"
            RowSpacing="8"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Border Grid.Row="0" BorderThickness="1" CornerRadius="12" Padding="10">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <StackPanel Spacing="3">
              <TextBlock Text="Work Thread" FontSize="19" FontWeight="SemiBold" />
              <TextBlock x:Name="WorkThreadStatusText"
                         Text="Work Thread: loading..."
                         TextWrapping="WrapWholeWords"
                         MaxLines="2"
                         FontSize="12"
                         FontWeight="SemiBold"
                         Opacity="0.84" />
              <TextBox x:Name="WorkThreadTitleBox"
                       PlaceholderText="Name this work thread..."
                       MinWidth="220"
                       MaxWidth="440"
                       FontSize="11"
                       TextWrapping="NoWrap" />
              <TextBlock x:Name="CurrentWindowText"
                         Text="Finding active context..."
                         TextWrapping="WrapWholeWords"
                         MaxLines="2"
                         FontSize="12"
                         Opacity="0.76" />
              <TextBlock x:Name="SidecarAttachmentText"
                         Text="Sidecar: Attach mode on; waiting for a target window."
                         TextWrapping="WrapWholeWords"
                         MaxLines="2"
                         FontSize="11"
                         Opacity="0.62" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Top">
              <Button Content="Sessions" Click="ToggleSessionManagerPanel_Click" FontSize="12" Padding="8,4" />
              <Button Content="Settings" Click="ToggleProviderSettingsPanel_Click" FontSize="12" Padding="8,4" />
              <Button Content="Tools" Click="ToggleDiagnosticsTargetPickerPanel_Click" FontSize="12" Padding="8,4" />
              <Button Content="Hide" Click="CollapseSidecarToHandle_Click" FontSize="12" Padding="8,4" />
            </StackPanel>
          </Grid>
        </Border>

        <Border x:Name="SessionBindingPanel"
                Grid.Row="1"
                BorderThickness="1"
                CornerRadius="12"
                Padding="10"
                Visibility="Collapsed">
          <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
            <TextBlock x:Name="SessionBindingStatusText"
                       Text="Window session: no pending connection. Click AI on another window to choose how to connect it."
                       TextWrapping="WrapWholeWords"
                       MaxLines="3"
                       FontSize="11"
                       Opacity="0.82" />
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
              <Button Content="Connect Current" Click="ConnectPendingTargetToCurrentSession_Click" FontSize="12" Padding="8,4" />
              <Button Content="New Window Session" Click="StartNewSessionForPendingTarget_Click" FontSize="12" Padding="8,4" />
              <Button Content="Detach" Click="DetachPendingTarget_Click" FontSize="12" Padding="8,4" />
            </StackPanel>
          </Grid>
        </Border>

        <Border x:Name="CurrentContextPanel" Grid.Row="2" BorderThickness="1" CornerRadius="12" Padding="10">
          <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
              <Border x:Name="ContextStatusPill"
                      BorderThickness="1"
                      CornerRadius="10"
                      Padding="8,2"
                      VerticalAlignment="Center">
                <TextBlock x:Name="ContextStatusText"
                           Text="No context"
                           FontSize="11"
                           Opacity="0.82" />
              </Border>
              <TextBlock Grid.Column="1"
                         Text="Connected context"
                         FontSize="12"
                         FontWeight="SemiBold"
                         Opacity="0.78"
                         VerticalAlignment="Center" />
            </Grid>

            <TextBlock x:Name="CurrentContextText"
                       Grid.Row="1"
                       Text="No resolved context yet. Threadline will use the app or tab it is attached to."
                       TextWrapping="WrapWholeWords"
                       MaxLines="3"
                       FontSize="11"
                       Opacity="0.78" />
          </Grid>
        </Border>

        <Border Grid.Row="3" BorderThickness="1" CornerRadius="12" Padding="0">
          <ScrollViewer x:Name="TranscriptScrollViewer"
                        VerticalScrollBarVisibility="Auto"
                        VerticalScrollMode="Enabled"
                        HorizontalScrollBarVisibility="Disabled"
                        HorizontalScrollMode="Disabled"
                        ZoomMode="Disabled"
                        Padding="8,6,8,12">
            <ItemsControl x:Name="TranscriptList">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderThickness="1"
                          CornerRadius="10"
                          Padding="10"
                          Margin="0,4,0,4"
                          HorizontalAlignment="Stretch">
                    <StackPanel Spacing="4">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding Speaker}"
                                   FontWeight="SemiBold"
                                   Opacity="0.90" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding TimestampDisplay}"
                                   FontSize="11"
                                   Opacity="0.58" />
                      </Grid>
                      <TextBlock Text="{Binding Message}"
                                 TextWrapping="WrapWholeWords"
                                 IsTextSelectionEnabled="True" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <Border Grid.Row="4" BorderThickness="1" CornerRadius="12" Padding="8">
          <Grid RowDefinitions="*,Auto,Auto" RowSpacing="6">
            <TextBox x:Name="QuestionBox"
                     PlaceholderText="Ask about this app, tab, document, or workflow..."
                     AcceptsReturn="True"
                     MinHeight="78"
                     TextWrapping="Wrap"
                     BorderThickness="0" />
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
              <TextBlock Text="Artifact actions" FontSize="11" Opacity="0.68" VerticalAlignment="Center" />
              <Button Content="Summary" Click="CreateSummaryArtifact_Click" FontSize="12" Padding="8,4" />
              <Button Content="Handoff" Click="CreateHandoffArtifact_Click" FontSize="12" Padding="8,4" />
              <Button Content="Decisions" Click="CreateDecisionsArtifact_Click" FontSize="12" Padding="8,4" />
              <Button Content="Risks" Click="CreateRisksArtifact_Click" FontSize="12" Padding="8,4" />
              <Button Content="Next Actions" Click="CreateNextActionsArtifact_Click" FontSize="12" Padding="8,4" />
            </StackPanel>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
              <Button Content="Copy Last" Click="CopyLastAnswer_Click" FontSize="12" Padding="8,4" />
              <Button Content="Copy All" Click="CopyConversation_Click" FontSize="12" Padding="8,4" />
              <Button Content="Clear" Click="ClearTranscript_Click" FontSize="12" Padding="8,4" />
              <Button Content="Ask" Click="TrustedAsk_Click" FontSize="12" Padding="12,4" />
            </StackPanel>
          </Grid>
        </Border>

        <ListView x:Name="TimelineList" Grid.Row="5" Height="28" FontSize="10" />
      </Grid>

      <Border x:Name="ShellOverlayPanel"
              Width="390"
              MaxWidth="430"
              HorizontalAlignment="Right"
              VerticalAlignment="Stretch"
              BorderThickness="1"
              CornerRadius="14"
              Padding="10"
              Visibility="Collapsed">
        <Grid RowDefinitions="Auto,*" RowSpacing="8">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBlock x:Name="ShellOverlayTitleText"
                       Text="Panel"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="Close" Click="CloseShellOverlayPanel_Click" FontSize="12" Padding="8,4" />
          </Grid>

          <Grid Grid.Row="1">
            <Border x:Name="WorkThreadSessionManagerPanel"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="10"
                    Visibility="Collapsed">
              <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <StackPanel>
                    <TextBlock Text="Sessions" FontSize="14" FontWeight="SemiBold" />
                    <TextBlock x:Name="WorkThreadListStatusText"
                               Text="Refresh to see recent Work Threads."
                               TextWrapping="WrapWholeWords"
                               MaxLines="2"
                               FontSize="11"
                               Opacity="0.72" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Top">
                    <Button Content="Refresh" Click="RefreshWorkThreads_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Resume" Click="ResumeSelectedWorkThread_Click" FontSize="12" Padding="8,4" />
                  </StackPanel>
                </Grid>

                <ListView x:Name="WorkThreadList"
                          Grid.Row="1"
                          Height="160"
                          SelectionMode="Single"
                          SelectionChanged="WorkThreadList_SelectionChanged"
                          FontSize="11"
                          HorizontalContentAlignment="Stretch">
                  <ListView.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}"
                                 FontSize="11"
                                 TextWrapping="WrapWholeWords"
                                 MaxLines="3"
                                 Opacity="0.88"
                                 Margin="0,2" />
                    </DataTemplate>
                  </ListView.ItemTemplate>
                </ListView>

                <TextBox x:Name="SessionManagerTitleBox"
                         Grid.Row="2"
                         PlaceholderText="Rename selected or active Work Thread..."
                         FontSize="11"
                         TextWrapping="NoWrap" />

                <StackPanel Grid.Row="3" Spacing="6">
                  <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                    <Button Content="New Thread" Click="NewWorkThread_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Resume Active" Click="ResumeWorkThread_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Close Active" Click="CloseWorkThread_Click" FontSize="12" Padding="8,4" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                    <Button Content="Rename Selected" Click="RenameSelectedWorkThread_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Tie Window" Click="TieCurrentWindowToSelectedThread_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Detach Window" Click="DetachCurrentWindowFromWorkThread_Click" FontSize="12" Padding="8,4" />
                  </StackPanel>
                </StackPanel>

                <TextBlock x:Name="WorkThreadSelectedText"
                           Grid.Row="4"
                           Text="Selected: none"
                           TextWrapping="WrapWholeWords"
                           MaxLines="2"
                           FontSize="11"
                           Opacity="0.72" />
              </Grid>
            </Border>

            <Border x:Name="ProviderSettingsPanel"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="10"
                    Visibility="Collapsed">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <StackPanel>
                    <TextBlock Text="Provider Settings" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="This panel stays open while you copy and paste provider details." TextWrapping="WrapWholeWords" FontSize="11" Opacity="0.72" />
                  </StackPanel>
                  <Button Grid.Column="1" Content="Close" Click="CloseProviderSettingsPanel_Click" FontSize="12" Padding="8,4" VerticalAlignment="Top" />
                </Grid>

                <Grid Grid.Row="1" RowDefinitions="Auto,Auto" RowSpacing="8">
                  <TextBlock x:Name="ProviderSettingsStatusText"
                             Text="Provider settings not saved yet."
                             TextWrapping="WrapWholeWords"
                             FontSize="11"
                             Opacity="0.82" />
                  <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="Use Defaults" Click="UseProviderDefaults_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Save Provider" Click="SaveProviderSettings_Click" FontSize="12" Padding="10,4" />
                  </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Chat provider" FontWeight="SemiBold" Margin="0,4,0,0" />
                    <ComboBox x:Name="ProviderBox" SelectedIndex="0" SelectionChanged="ProviderBox_SelectionChanged" HorizontalAlignment="Stretch">
                      <ComboBoxItem Content="OpenAI" />
                      <ComboBoxItem Content="Claude" />
                      <ComboBoxItem Content="Gemini" />
                      <ComboBoxItem Content="DeepSeek" />
                      <ComboBoxItem Content="OpenRouter" />
                      <ComboBoxItem Content="Local" />
                    </ComboBox>

                    <TextBlock Text="Settings provider" FontWeight="SemiBold" Margin="0,4,0,0" />
                    <ComboBox x:Name="SettingsProviderBox" SelectedIndex="0" SelectionChanged="SettingsProviderBox_SelectionChanged" HorizontalAlignment="Stretch">
                      <ComboBoxItem Content="OpenAI" />
                      <ComboBoxItem Content="Claude" />
                      <ComboBoxItem Content="Gemini" />
                      <ComboBoxItem Content="DeepSeek" />
                      <ComboBoxItem Content="OpenRouter" />
                      <ComboBoxItem Content="Local" />
                    </ComboBox>

                    <TextBox x:Name="ProviderBaseUrlBox" Header="Base URL" PlaceholderText="https://api.openai.com/v1/" TextWrapping="NoWrap" />
                    <TextBox x:Name="ProviderModelBox" Header="Default model" PlaceholderText="gpt-4.1-mini" TextWrapping="NoWrap" />
                    <PasswordBox x:Name="ProviderApiKeyBox" Header="API key" PlaceholderText="Stored through Threadline local secret storage" />
                    <TextBlock x:Name="ProviderSettingsHintText"
                               Text="For OpenAI, paste your API key once, then click Save Provider. The key is stored by the local Threadline service."
                               TextWrapping="WrapWholeWords"
                               FontSize="11"
                               Opacity="0.74" />

                    <TextBlock Text="Privacy / trust controls" FontWeight="SemiBold" Margin="0,8,0,0" />
                    <CheckBox x:Name="AllowProviderContextToggle"
                              Content="Send resolved context to provider"
                              IsChecked="True"
                              FontSize="12" />
                    <CheckBox x:Name="SaveWorkThreadMemoryToggle"
                              Content="Save messages and context to Work Thread memory"
                              IsChecked="True"
                              FontSize="12" />
                    <CheckBox x:Name="ShowContextReceiptsToggle"
                              Content="Show Context Receipt under answers"
                              IsChecked="True"
                              FontSize="12" />
                    <TextBlock x:Name="TrustControlStatusText"
                               Text="Blocked sources stay out of provider prompts. Receipts show what was used and what was not used."
                               TextWrapping="WrapWholeWords"
                               FontSize="11"
                               Opacity="0.74" />
                  </StackPanel>
                </ScrollViewer>
              </Grid>
            </Border>

            <Border x:Name="DiagnosticsTargetPickerPanel"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="10"
                    Visibility="Collapsed">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="8">
                  <TextBlock Text="Diagnostics / Target Picker" FontSize="16" FontWeight="SemiBold" />
                  <TextBlock x:Name="ServiceStatusText" Text="Service: unknown" TextWrapping="WrapWholeWords" FontSize="11" Opacity="0.72" />
                  <TextBlock x:Name="SessionText" Text="No active Threadline session." TextWrapping="WrapWholeWords" FontSize="11" Opacity="0.72" />

                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="New Chat" Click="NewChat_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Use Session" Click="UseActiveSession_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Start Session" Click="StartSession_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Check" Click="CheckService_Click" FontSize="12" Padding="8,4" />
                  </StackPanel>

                  <TextBlock Text="Target picker" FontWeight="SemiBold" Margin="0,6,0,0" />
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="Refresh" Click="RefreshOpenWindows_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Use" Click="UseSelectedTarget_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Follow / Lock" Click="ToggleFollowLock_Click" FontSize="12" Padding="8,4" />
                  </StackPanel>
                  <ListView x:Name="OpenWindowsList"
                            Height="190"
                            SelectionMode="Single"
                            FontSize="11"
                            HorizontalContentAlignment="Stretch">
                    <ListView.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   FontSize="11"
                                   TextWrapping="WrapWholeWords"
                                   MaxLines="3"
                                   Opacity="0.86"
                                   Margin="0,2" />
                      </DataTemplate>
                    </ListView.ItemTemplate>
                  </ListView>

                  <Border x:Name="DiagnosticsPanel" BorderThickness="1" CornerRadius="8" Padding="6" Visibility="Collapsed">
                    <TextBlock x:Name="DiagnosticsText"
                               Text="No diagnostics yet."
                               TextWrapping="WrapWholeWords"
                               FontSize="10"
                               Opacity="0.82" />
                  </Border>

                  <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                    <Button Content="Diagnostics" Click="ToggleDiagnostics_Click" FontSize="12" Padding="8,4" />
                    <Button Content="Clear Context" Click="ClearSharedContext_Click" FontSize="12" Padding="8,4" />
                  </StackPanel>
                </StackPanel>
              </ScrollViewer>
            </Border>
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
