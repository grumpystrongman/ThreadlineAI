<Window
    x:Class="Threadline.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ThreadlineAI Sidecar">
  <Grid x:Name="RootShell" ColumnDefinitions="Auto,*" Background="Transparent">
    <Border x:Name="EdgeHandlePanel"
            Width="44"
            Visibility="Collapsed"
            Opacity="0.82"
            CornerRadius="12"
            BorderThickness="1"
            Padding="6"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            PointerEntered="ExpandSidecarFromHandle"
            PointerPressed="ExpandSidecarFromHandle">
      <Grid RowDefinitions="*,Auto,*">
        <StackPanel Grid.Row="1" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
          <TextBlock Text="✦" FontSize="18" HorizontalAlignment="Center" />
          <TextBlock Text="AI" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid x:Name="ChatShellPanel"
          Grid.Column="1"
          Padding="12"
          RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto"
          RowSpacing="8"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
      <Border BorderThickness="1" CornerRadius="12" Padding="10">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
          <StackPanel Spacing="3">
            <TextBlock Text="Threadline" FontSize="19" FontWeight="SemiBold" />
            <TextBlock x:Name="CurrentWindowText"
                       Text="Finding active context..."
                       TextWrapping="WrapWholeWords"
                       MaxLines="2"
                       FontSize="12"
                       Opacity="0.76" />
            <TextBlock x:Name="SidecarAttachmentText"
                       Text="Sidecar: Attach mode on; waiting for a target window."
                       TextWrapping="WrapWholeWords"
                       MaxLines="2"
                       FontSize="11"
                       Opacity="0.62" />
          </StackPanel>

          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Top">
            <Button Content="Start Session" Click="StartSession_Click" FontSize="12" Padding="8,4" />
            <CheckBox x:Name="AttachSidecarToggle"
                      Content="Attach"
                      IsChecked="True"
                      Click="ToggleAttachSidecarMode_Click"
                      FontSize="11"
                      VerticalAlignment="Center" />
            <Button Content="Settings" Click="ToggleProviderSettingsPanel_Click" FontSize="12" Padding="8,4" />
            <Button Content="Hide" Click="CollapseSidecarToHandle_Click" FontSize="12" Padding="8,4" />
            <Button Content="⋯" FontSize="16" Padding="8,2">
              <Button.Flyout>
                <Flyout>
                  <ScrollViewer Width="360" MaxHeight="520" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="8" Padding="4">
                      <TextBlock Text="Sidecar controls" FontSize="16" FontWeight="SemiBold" />
                      <TextBlock x:Name="ServiceStatusText" Text="Service: unknown" TextWrapping="WrapWholeWords" FontSize="11" Opacity="0.72" />
                      <TextBlock x:Name="SessionText" Text="No active Threadline session." TextWrapping="WrapWholeWords" FontSize="11" Opacity="0.72" />

                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="New" Click="NewChat_Click" FontSize="12" Padding="8,4" />
                        <Button Content="Use Session" Click="UseActiveSession_Click" FontSize="12" Padding="8,4" />
                        <Button Content="Check" Click="CheckService_Click" FontSize="12" Padding="8,4" />
                      </StackPanel>

                      <TextBlock Text="Target picker" FontWeight="SemiBold" Margin="0,6,0,0" />
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="Refresh" Click="RefreshOpenWindows_Click" FontSize="12" Padding="8,4" />
                        <Button Content="Use" Click="UseSelectedTarget_Click" FontSize="12" Padding="8,4" />
                        <Button Content="Follow / Lock" Click="ToggleFollowLock_Click" FontSize="12" Padding="8,4" />
                      </StackPanel>
                      <ListView x:Name="OpenWindowsList"
                                Height="170"
                                SelectionMode="Single"
                                FontSize="11"
                                HorizontalContentAlignment="Stretch">
                        <ListView.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontSize="11"
                                       TextWrapping="WrapWholeWords"
                                       MaxLines="3"
                                       Opacity="0.86"
                                       Margin="0,2" />
                          </DataTemplate>
                        </ListView.ItemTemplate>
                      </ListView>

                      <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                        <Button Content="Diagnostics" Click="ToggleDiagnostics_Click" FontSize="12" Padding="8,4" />
                        <Button Content="Clear Context" Click="ClearSharedContext_Click" FontSize="12" Padding="8,4" />
                      </StackPanel>
                    </StackPanel>
                  </ScrollViewer>
                </Flyout>
              </Button.Flyout>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <Border x:Name="SessionBindingPanel" Grid.Row="1" BorderThickness="1" CornerRadius="12" Padding="10">
        <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
          <TextBlock x:Name="SessionBindingStatusText"
                     Text="Window session: no pending connection. Click AI on another window to choose how to connect it."
                     TextWrapping="WrapWholeWords"
                     MaxLines="3"
                     FontSize="11"
                     Opacity="0.82" />
          <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
            <Button Content="Connect Current" Click="ConnectPendingTargetToCurrentSession_Click" FontSize="12" Padding="8,4" />
            <Button Content="New Window Session" Click="StartNewSessionForPendingTarget_Click" FontSize="12" Padding="8,4" />
            <Button Content="Detach" Click="DetachPendingTarget_Click" FontSize="12" Padding="8,4" />
          </StackPanel>
        </Grid>
      </Border>

      <Border x:Name="ProviderSettingsPanel" Grid.Row="2" BorderThickness="1" CornerRadius="12" Padding="10" Visibility="Collapsed">
        <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <StackPanel>
              <TextBlock Text="Provider Settings" FontSize="16" FontWeight="SemiBold" />
              <TextBlock Text="This panel stays open while you copy and paste provider details." TextWrapping="WrapWholeWords" FontSize="11" Opacity="0.72" />
            </StackPanel>
            <Button Grid.Column="1" Content="Close" Click="CloseProviderSettingsPanel_Click" FontSize="12" Padding="8,4" VerticalAlignment="Top" />
          </Grid>

          <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBlock x:Name="ProviderSettingsStatusText"
                       Text="Provider settings not saved yet."
                       TextWrapping="WrapWholeWords"
                       FontSize="11"
                       Opacity="0.82"
                       VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
              <Button Content="Use Defaults" Click="UseProviderDefaults_Click" FontSize="12" Padding="8,4" />
              <Button Content="Save Provider" Click="SaveProviderSettings_Click" FontSize="12" Padding="10,4" />
            </StackPanel>
          </Grid>

          <ScrollViewer Grid.Row="2" MaxHeight="260" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="8">
              <TextBlock Text="Chat provider" FontWeight="SemiBold" Margin="0,4,0,0" />
              <ComboBox x:Name="ProviderBox" SelectedIndex="0" SelectionChanged="ProviderBox_SelectionChanged" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="OpenAI" />
                <ComboBoxItem Content="Claude" />
                <ComboBoxItem Content="Gemini" />
                <ComboBoxItem Content="DeepSeek" />
                <ComboBoxItem Content="OpenRouter" />
                <ComboBoxItem Content="Local" />
              </ComboBox>

              <TextBlock Text="Settings provider" FontWeight="SemiBold" Margin="0,4,0,0" />
              <ComboBox x:Name="SettingsProviderBox" SelectedIndex="0" SelectionChanged="SettingsProviderBox_SelectionChanged" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="OpenAI" />
                <ComboBoxItem Content="Claude" />
                <ComboBoxItem Content="Gemini" />
                <ComboBoxItem Content="DeepSeek" />
                <ComboBoxItem Content="OpenRouter" />
                <ComboBoxItem Content="Local" />
              </ComboBox>

              <TextBox x:Name="ProviderBaseUrlBox" Header="Base URL" PlaceholderText="https://api.openai.com/v1/" TextWrapping="NoWrap" />
              <TextBox x:Name="ProviderModelBox" Header="Default model" PlaceholderText="gpt-4.1-mini" TextWrapping="NoWrap" />
              <PasswordBox x:Name="ProviderApiKeyBox" Header="API key" PlaceholderText="Stored through Threadline local secret storage" />
              <TextBlock x:Name="ProviderSettingsHintText"
                         Text="For OpenAI, paste your API key once, then click Save Provider. The key is stored by the local Threadline service."
                         TextWrapping="WrapWholeWords"
                         FontSize="11"
                         Opacity="0.74" />
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>

      <Border x:Name="CurrentContextPanel" Grid.Row="3" BorderThickness="1" CornerRadius="12" Padding="10">
        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
            <Border x:Name="ContextStatusPill"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="8,2"
                    VerticalAlignment="Center">
              <TextBlock x:Name="ContextStatusText"
                         Text="No context"
                         FontSize="11"
                         Opacity="0.82" />
            </Border>
            <TextBlock Grid.Column="1"
                       Text="Connected context"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Opacity="0.78"
                       VerticalAlignment="Center" />
          </Grid>

          <TextBlock x:Name="CurrentContextText"
                     Grid.Row="1"
                     Text="No resolved context yet. Threadline will use the app or tab it is attached to."
                     TextWrapping="WrapWholeWords"
                     MaxLines="3"
                     FontSize="11"
                     Opacity="0.78" />

          <Border x:Name="DiagnosticsPanel" Grid.Row="2" BorderThickness="1" CornerRadius="8" Padding="6" Visibility="Collapsed">
            <TextBlock x:Name="DiagnosticsText"
                       Text="No diagnostics yet."
                       TextWrapping="WrapWholeWords"
                       FontSize="10"
                       Opacity="0.82" />
          </Border>
        </Grid>
      </Border>

      <Border Grid.Row="4" BorderThickness="1" CornerRadius="12" Padding="0">
        <ScrollViewer x:Name="TranscriptScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Enabled"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalScrollMode="Disabled"
                      ZoomMode="Disabled"
                      Padding="8,6,8,12">
          <ItemsControl x:Name="TranscriptList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border BorderThickness="1"
                        CornerRadius="10"
                        Padding="10"
                        Margin="0,4,0,4"
                        HorizontalAlignment="Stretch">
                  <StackPanel Spacing="4">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="{Binding Speaker}"
                                 FontWeight="SemiBold"
                                 Opacity="0.90" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding TimestampDisplay}"
                                 FontSize="11"
                                 Opacity="0.58" />
                    </Grid>
                    <TextBlock Text="{Binding Message}"
                               TextWrapping="WrapWholeWords"
                               IsTextSelectionEnabled="True" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

      <Border Grid.Row="5" BorderThickness="1" CornerRadius="12" Padding="8">
        <Grid RowDefinitions="*,Auto" RowSpacing="6">
          <TextBox x:Name="QuestionBox"
                   PlaceholderText="Ask about this app, tab, document, or workflow..."
                   AcceptsReturn="True"
                   MinHeight="78"
                   TextWrapping="Wrap"
                   BorderThickness="0" />
          <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
            <Button Content="Copy Last" Click="CopyLastAnswer_Click" FontSize="12" Padding="8,4" />
            <Button Content="Copy All" Click="CopyConversation_Click" FontSize="12" Padding="8,4" />
            <Button Content="Clear" Click="ClearTranscript_Click" FontSize="12" Padding="8,4" />
            <Button Content="Ask" Click="Ask_Click" FontSize="12" Padding="12,4" />
          </StackPanel>
        </Grid>
      </Border>

      <ListView x:Name="TimelineList" Grid.Row="6" Height="28" FontSize="10" />
    </Grid>
  </Grid>
</Window>