<Window
    x:Class="Threadline.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ThreadlineAI Sidecar">

  <Grid x:Name="RootShell" ColumnDefinitions="Auto,*" Background="#F8FAFF" Loaded="RootShell_Loaded">
    <Grid.Resources>
      <!-- Keep custom sidecar buttons readable through WinUI hover/pressed states. -->
      <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#111827" />
      <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#111827" />
      <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#9CA3AF" />
      <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#EAF2FF" />
      <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#DBEAFE" />
      <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#9DB7DD" />
      <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#7EA2D6" />

      <Style x:Key="SidecarButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="#111827" />
        <Setter Property="Background" Value="#F8FAFF" />
        <Setter Property="BorderBrush" Value="#DCE6F5" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="7,4" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="CornerRadius" Value="4" />
      </Style>

      <Style x:Key="PrimarySidecarButtonStyle" TargetType="Button" BasedOn="{StaticResource SidecarButtonStyle}">
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="Background" Value="#2563EB" />
        <Setter Property="BorderBrush" Value="#1D4ED8" />
        <Setter Property="FontWeight" Value="SemiBold" />
      </Style>

      <Style x:Key="WarmSidecarButtonStyle" TargetType="Button" BasedOn="{StaticResource SidecarButtonStyle}">
        <Setter Property="Foreground" Value="#7C2D12" />
        <Setter Property="Background" Value="#FFEDD5" />
        <Setter Property="BorderBrush" Value="#FDBA74" />
      </Style>
    </Grid.Resources>

    <Border x:Name="EdgeHandlePanel"
            Width="44"
            Visibility="Collapsed"
            Opacity="0.90"
            CornerRadius="14"
            BorderThickness="1"
            BorderBrush="#D7E2F3"
            Background="#F8FBFF"
            Padding="6"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            PointerEntered="ExpandSidecarFromHandle"
            PointerPressed="ExpandSidecarFromHandle">
      <Grid RowDefinitions="*,Auto,*">
        <StackPanel Grid.Row="1" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
          <TextBlock Text="◉" FontSize="18" Foreground="#2563EB" HorizontalAlignment="Center" />
          <TextBlock Text="AI" FontSize="12" FontWeight="SemiBold" Foreground="#111827" HorizontalAlignment="Center" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid x:Name="ChatShellPanel"
          Grid.Column="1"
          Background="#F8FAFF"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">

      <Grid RowDefinitions="Auto,Auto,*,Auto,Auto"
            RowSpacing="8"
            Padding="9"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">

        <!-- Header: quiet by default; advanced controls live in the drawer. -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#DCE6F5" BorderThickness="1" CornerRadius="18" Padding="10,8">
          <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
              <Border Width="30" Height="30" CornerRadius="15" Background="#EEF5FF" BorderBrush="#C8DBFF" BorderThickness="1" VerticalAlignment="Center">
                <TextBlock Text="◉" FontSize="16" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>

              <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                <TextBlock Text="ThreadlineAI" FontSize="17" FontWeight="SemiBold" Foreground="#111827" />
                <TextBlock x:Name="SidecarAttachmentText"
                           Text="Following your active work."
                           TextWrapping="WrapWholeWords"
                           MaxLines="1"
                           FontSize="10"
                           Foreground="#6B7280" />
              </StackPanel>

              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="New"
                        Click="NewChat_Click"
                        MinWidth="44"
                        Style="{StaticResource SidecarButtonStyle}" />
                <Button Content="Details"
                        Click="ToggleDiagnosticsTargetPickerPanel_Click"
                        MinWidth="58"
                        Style="{StaticResource SidecarButtonStyle}" />
                <Button x:Name="AttachSidecarButton"
                        Content="Resize"
                        Click="ToggleAttachSidecar_Click"
                        MinWidth="58"
                        Style="{StaticResource SidecarButtonStyle}" />
                <Button Content="×"
                        Click="CollapseSidecarToHandle_Click"
                        FontSize="14"
                        MinWidth="32"
                        Padding="8,3"
                        Style="{StaticResource SidecarButtonStyle}" />
              </StackPanel>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
              <TextBlock x:Name="WorkThreadStatusText"
                         Text="Work Thread: ready"
                         FontSize="12"
                         FontWeight="SemiBold"
                         Foreground="#111827"
                         TextWrapping="WrapWholeWords"
                         TextTrimming="CharacterEllipsis"
                         MaxLines="1"
                         VerticalAlignment="Center" />
              <Button Grid.Column="1"
                      Content="Sessions"
                      Click="ToggleSessionManagerPanel_Click"
                      Style="{StaticResource SidecarButtonStyle}"
                      MinWidth="68" />
              <Button Grid.Column="2"
                      Content="Settings"
                      Click="ToggleProviderSettingsPanel_Click"
                      Style="{StaticResource SidecarButtonStyle}"
                      MinWidth="68" />
            </Grid>

            <TextBox x:Name="WorkThreadTitleBox"
                     PlaceholderText="Name this work thread..."
                     FontSize="11"
                     TextWrapping="NoWrap"
                     BorderThickness="0"
                     Background="Transparent"
                     Foreground="#4B5563"
                     Height="1"
                     Opacity="0" />
          </Grid>
        </Border>

        <!-- Pending binding only appears when there is something actionable. -->
        <Border x:Name="SessionBindingPanel"
                Grid.Row="1"
                Background="#FFF7ED"
                BorderBrush="#FDBA74"
                BorderThickness="1"
                CornerRadius="14"
                Padding="10"
                Visibility="Collapsed">
          <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
            <TextBlock x:Name="SessionBindingStatusText"
                       Text="Pending window connection. Choose how to connect it."
                       TextWrapping="WrapWholeWords"
                       MaxLines="2"
                       FontSize="11"
                       Foreground="#7C2D12" />
            <Grid Grid.Row="1" ColumnDefinitions="*,*,Auto" ColumnSpacing="6">
              <Button Content="Connect"
                      Click="ConnectPendingTargetToCurrentSession_Click"
                      Style="{StaticResource WarmSidecarButtonStyle}" />
              <Button Grid.Column="1"
                      Content="New session"
                      Click="StartNewSessionForPendingTarget_Click"
                      Style="{StaticResource WarmSidecarButtonStyle}" />
              <Button Grid.Column="2"
                      Content="Detach"
                      Click="DetachPendingTarget_Click"
                      Style="{StaticResource WarmSidecarButtonStyle}" />
            </Grid>
          </Grid>
        </Border>

        <!-- Chat body: familiar LLM surface with only a small context signal. -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="8" MinHeight="220">
          <Border x:Name="CurrentContextPanel" Background="#FFFFFF" BorderBrush="#DCE6F5" BorderThickness="1" CornerRadius="18" Padding="9,7">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
              <Border x:Name="ContextStatusPill" Width="24" Height="24" CornerRadius="12" Background="#EEF5FF">
                <TextBlock x:Name="ContextStatusText" Text="◉" Foreground="#2563EB" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>

              <StackPanel Grid.Column="1" Spacing="1">
                <TextBlock Text="Sharing current context" FontSize="11" FontWeight="SemiBold" Foreground="#111827" />
                <TextBlock x:Name="CurrentContextText"
                           Text="No source selected yet."
                           TextWrapping="WrapWholeWords"
                           MaxLines="2"
                           FontSize="10"
                           Foreground="#6B7280" />
              </StackPanel>

              <StackPanel Grid.Column="2" Spacing="1" MinWidth="90" HorizontalAlignment="Right">
                <TextBlock x:Name="ReceiptTrustText"
                           Text="No context"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="#16A34A"
                           TextAlignment="Right"
                           TextWrapping="WrapWholeWords"
                           MaxLines="1" />
                <TextBlock x:Name="ReceiptSourceText"
                           Text="No receipt"
                           FontSize="10"
                           Foreground="#6B7280"
                           TextAlignment="Right"
                           TextWrapping="WrapWholeWords"
                           MaxLines="1" />
              </StackPanel>
            </Grid>
          </Border>

          <Border Grid.Row="1" Background="#FCFDFF" BorderBrush="#DCE6F5" BorderThickness="1" CornerRadius="20" Padding="0" MinHeight="190">
            <ScrollViewer x:Name="TranscriptScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          VerticalScrollMode="Enabled"
                          HorizontalScrollBarVisibility="Disabled"
                          HorizontalScrollMode="Disabled"
                          ZoomMode="Disabled"
                          Padding="10,10,10,10">
              <ItemsControl x:Name="TranscriptList">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="#FFFFFF"
                            BorderBrush="#E5EDF8"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="12"
                            Margin="0,5,0,5"
                            HorizontalAlignment="Stretch">
                      <StackPanel Spacing="7">
                        <Grid ColumnDefinitions="*,Auto">
                          <TextBlock Text="{Binding Speaker}" FontSize="12" FontWeight="SemiBold" Foreground="#111827" />
                          <TextBlock Grid.Column="1" Text="{Binding TimestampDisplay}" FontSize="10" Foreground="#6B7280" />
                        </Grid>
                        <TextBlock Text="{Binding Message}"
                                   TextWrapping="WrapWholeWords"
                                   IsTextSelectionEnabled="True"
                                   Foreground="#111827"
                                   FontSize="13"
                                   LineHeight="18" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>
        </Grid>

        <!-- Composer: clean chat-first entry point; features are reachable through + and Details. -->
        <Border Grid.Row="3" Background="#FFFFFF" BorderBrush="#DCE6F5" BorderThickness="1" CornerRadius="20" Padding="8">
          <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
            <TextBox x:Name="QuestionBox"
                     PlaceholderText="Ask ThreadlineAI..."
                     AcceptsReturn="True"
                     Height="64"
                     MaxHeight="88"
                     TextWrapping="Wrap"
                     BorderThickness="0"
                     Background="Transparent"
                     FontSize="13" />

            <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="6">
              <Button Content="+"
                      Click="ToggleDiagnosticsTargetPickerPanel_Click"
                      MinWidth="34"
                      Style="{StaticResource SidecarButtonStyle}" />
              <Button Grid.Column="1"
                      Content="Tools"
                      Click="ToggleDiagnosticsTargetPickerPanel_Click"
                      MinWidth="54"
                      Style="{StaticResource SidecarButtonStyle}" />
              <TextBlock Grid.Column="2"
                         x:Name="TrustControlStatusText"
                         Text="Governed"
                         FontSize="10"
                         Foreground="#6B7280"
                         TextTrimming="CharacterEllipsis"
                         VerticalAlignment="Center" />
              <Button Grid.Column="3"
                      Content="Ask"
                      Click="TrustedAsk_Click"
                      MinWidth="64"
                      Style="{StaticResource PrimarySidecarButtonStyle}" />
            </Grid>
          </Grid>
        </Border>

        <ListView x:Name="TimelineList" Grid.Row="4" Height="1" Visibility="Collapsed" />
      </Grid>

      <!-- Drawer: advanced capabilities stay available without crowding the conversation. -->
      <Border x:Name="ShellOverlayPanel"
              Width="372"
              MaxWidth="410"
              MaxHeight="720"
              Margin="10"
              HorizontalAlignment="Right"
              VerticalAlignment="Stretch"
              Background="#FFFFFF"
              BorderBrush="#DCE6F5"
              BorderThickness="1"
              CornerRadius="18"
              Padding="10"
              Visibility="Collapsed">
        <Grid RowDefinitions="Auto,*" RowSpacing="8">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <StackPanel>
              <TextBlock x:Name="ShellOverlayTitleText" Text="Panel" FontSize="16" FontWeight="SemiBold" Foreground="#111827" />
              <TextBlock Text="Context, tools, settings, and diagnostics" FontSize="10" Foreground="#6B7280" />
            </StackPanel>
            <Button Grid.Column="1" Content="Close" Click="CloseShellOverlayPanel_Click" Style="{StaticResource SidecarButtonStyle}" />
          </Grid>

          <Grid Grid.Row="1">
            <Border x:Name="WorkThreadSessionManagerPanel" BorderThickness="1" BorderBrush="#E5EDF8" CornerRadius="14" Padding="10" Visibility="Collapsed">
              <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <StackPanel>
                    <TextBlock Text="Sessions" FontSize="14" FontWeight="SemiBold" Foreground="#111827" />
                    <TextBlock x:Name="WorkThreadListStatusText" Text="Refresh to see recent Work Threads." TextWrapping="WrapWholeWords" MaxLines="2" FontSize="11" Foreground="#6B7280" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Top">
                    <Button Content="Refresh" Click="RefreshWorkThreads_Click" Style="{StaticResource SidecarButtonStyle}" />
                    <Button Content="Resume" Click="ResumeSelectedWorkThread_Click" Style="{StaticResource SidecarButtonStyle}" />
                  </StackPanel>
                </Grid>
                <ListView x:Name="WorkThreadList" Grid.Row="1" Height="220" SelectionMode="Single" SelectionChanged="WorkThreadList_SelectionChanged" FontSize="11" HorizontalContentAlignment="Stretch" />
                <TextBox x:Name="SessionManagerTitleBox" Grid.Row="2" PlaceholderText="Rename selected or active Work Thread..." FontSize="11" TextWrapping="NoWrap" />
                <StackPanel Grid.Row="3" Spacing="6">
                  <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                    <Button Content="New" Click="NewWorkThread_Click" Style="{StaticResource SidecarButtonStyle}" />
                    <Button Grid.Column="1" Content="Resume Active" Click="ResumeWorkThread_Click" Style="{StaticResource SidecarButtonStyle}" />
                    <Button Grid.Column="2" Content="Close Active" Click="CloseWorkThread_Click" Style="{StaticResource SidecarButtonStyle}" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                    <Button Content="Rename" Click="RenameSelectedWorkThread_Click" Style="{StaticResource SidecarButtonStyle}" />
                    <Button Grid.Column="1" Content="Tie Window" Click="TieCurrentWindowToSelectedThread_Click" Style="{StaticResource SidecarButtonStyle}" />
                    <Button Grid.Column="2" Content="Detach" Click="DetachCurrentWindowFromWorkThread_Click" Style="{StaticResource SidecarButtonStyle}" />
                  </Grid>
                  <TextBlock x:Name="WorkThreadSelectedText" Text="Selected: none" TextWrapping="WrapWholeWords" MaxLines="2" FontSize="10" Foreground="#6B7280" />
                </StackPanel>
              </Grid>
            </Border>

            <Border x:Name="ProviderSettingsPanel" BorderThickness="1" BorderBrush="#E5EDF8" CornerRadius="14" Padding="10" Visibility="Collapsed">
              <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="650">
                <StackPanel Spacing="8">
                  <TextBlock Text="ChatGPT / Provider setup" FontSize="15" FontWeight="SemiBold" Foreground="#111827" />
                  <TextBlock x:Name="ProviderSettingsStatusText" Text="Choose OpenAI, paste your key, then Save Provider." TextWrapping="WrapWholeWords" FontSize="11" Foreground="#6B7280" />
                  <TextBlock Text="Chat provider" FontWeight="SemiBold" FontSize="11" Foreground="#111827" />
                  <ComboBox x:Name="ProviderBox" SelectedIndex="0" SelectionChanged="ProviderBox_SelectionChanged" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="OpenAI" />
                    <ComboBoxItem Content="Gemini" />
                    <ComboBoxItem Content="DeepSeek" />
                    <ComboBoxItem Content="OpenRouter" />
                    <ComboBoxItem Content="Local" />
                  </ComboBox>
                  <TextBlock Text="Settings provider" FontWeight="SemiBold" FontSize="11" Foreground="#111827" />
                  <ComboBox x:Name="SettingsProviderBox" SelectedIndex="0" SelectionChanged="SettingsProviderBox_SelectionChanged" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="OpenAI" />
                    <ComboBoxItem Content="Gemini" />
                    <ComboBoxItem Content="DeepSeek" />
                    <ComboBoxItem Content="OpenRouter" />
                    <ComboBoxItem Content="Local" />
                  </ComboBox>
                  <TextBox x:Name="ProviderBaseUrlBox" Header="Base URL" PlaceholderText="https://api.openai.com/v1/" TextWrapping="NoWrap" />
                  <TextBox x:Name="ProviderModelBox" Header="Default model" PlaceholderText="gpt-4.1-mini" TextWrapping="NoWrap" />
                  <PasswordBox x:Name="ProviderApiKeyBox" Header="API key" PlaceholderText="Stored locally by Threadline" />
                  <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                    <Button Content="Defaults" Click="UseProviderDefaults_Click" Style="{StaticResource SidecarButtonStyle}" />
                    <Button Content="Save Provider" Click="SaveProviderSettings_Click" Style="{StaticResource PrimarySidecarButtonStyle}" />
                  </StackPanel>
                  <TextBlock x:Name="ProviderSettingsHintText" Text="OpenAI default: https://api.openai.com/v1/ with model gpt-4.1-mini. Your key is stored through Threadline local secret storage." TextWrapping="WrapWholeWords" FontSize="10" Foreground="#6B7280" />
                </StackPanel>
              </ScrollViewer>
            </Border>

            <Border x:Name="DiagnosticsTargetPickerPanel" BorderThickness="1" BorderBrush="#E5EDF8" CornerRadius="14" Padding="10" Visibility="Collapsed">
              <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="650">
                <StackPanel Spacing="10">
                  <TextBlock Text="Context &amp; tools" FontSize="15" FontWeight="SemiBold" Foreground="#111827" />
                  <TextBlock Text="Everything powerful is still here; the main sidecar stays focused on conversation." FontSize="11" Foreground="#6B7280" TextWrapping="WrapWholeWords" />

                  <Border BorderBrush="#E5EDF8" BorderThickness="1" CornerRadius="12" Padding="8">
                    <StackPanel Spacing="6">
                      <TextBlock Text="Service and session" FontWeight="SemiBold" FontSize="11" Foreground="#111827" />
                      <TextBlock x:Name="ServiceStatusText" Text="Service: starting..." TextWrapping="WrapWholeWords" FontSize="11" Foreground="#6B7280" />
                      <TextBlock x:Name="SessionText" Text="No active Threadline session." TextWrapping="WrapWholeWords" FontSize="11" Foreground="#6B7280" />
                      <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="6" RowSpacing="6">
                        <Button Content="New Chat" Click="NewChat_Click" Style="{StaticResource SidecarButtonStyle}" />
                        <Button Grid.Column="1" Content="Use Session" Click="UseActiveSession_Click" Style="{StaticResource SidecarButtonStyle}" />
                        <Button Grid.Row="1" Content="Start Session" Click="StartSession_Click" Style="{StaticResource SidecarButtonStyle}" />
                        <Button Grid.Row="1" Grid.Column="1" Content="Check Service" Click="CheckService_Click" Style="{StaticResource SidecarButtonStyle}" />
                      </Grid>
                    </StackPanel>
                  </Border>

                  <Border BorderBrush="#E5EDF8" BorderThickness="1" CornerRadius="12" Padding="8">
                    <StackPanel Spacing="6">
                      <TextBlock Text="Target picker" FontWeight="SemiBold" FontSize="11" Foreground="#111827" />
                      <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                        <Button Content="Refresh" Click="RefreshOpenWindows_Click" Style="{StaticResource SidecarButtonStyle}" />
                        <Button Grid.Column="1" Content="Use" Click="UseSelectedTarget_Click" Style="{StaticResource SidecarButtonStyle}" />
                        <Button Grid.Column="2" Content="Follow/Lock" Click="ToggleFollowLock_Click" Style="{StaticResource SidecarButtonStyle}" />
                      </Grid>
                      <ListView x:Name="OpenWindowsList" Height="180" SelectionMode="Single" FontSize="11" HorizontalContentAlignment="Stretch" />
                    </StackPanel>
                  </Border>

                  <Border BorderBrush="#E5EDF8" BorderThickness="1" CornerRadius="12" Padding="8">
                    <StackPanel Spacing="6">
                      <TextBlock Text="Artifact actions" FontWeight="SemiBold" FontSize="11" Foreground="#111827" />
                      <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="6">
                        <Button Content="Summary" Click="SummaryArtifactAction_Click" Style="{StaticResource SidecarButtonStyle}" />
                        <Button Grid.Column="1" Content="Handoff" Click="HandoffArtifactAction_Click" Style="{StaticResource SidecarButtonStyle}" />
                        <Button Grid.Column="2" Content="Decide" Click="DecisionsArtifactAction_Click" Style="{StaticResource SidecarButtonStyle}" />
                        <Button Grid.Row="1" Content="Risks" Click="RisksArtifactAction_Click" Style="{StaticResource SidecarButtonStyle}" />
                        <Button Grid.Row="1" Grid.Column="1" Content="Next" Click="NextActionsArtifactAction_Click" Style="{StaticResource SidecarButtonStyle}" />
                        <Button Grid.Row="1" Grid.Column="2" Content="Regen" Click="RegenerateArtifactAction_Click" Style="{StaticResource SidecarButtonStyle}" />
                        <Button Grid.Row="2" Content="Copy Art" Click="CopyArtifactAction_Click" Style="{StaticResource SidecarButtonStyle}" />
                        <Button Grid.Row="2" Grid.Column="1" Content="Export" Click="ExportArtifactAction_Click" Style="{StaticResource SidecarButtonStyle}" />
                      </Grid>
                    </StackPanel>
                  </Border>

                  <Border BorderBrush="#E5EDF8" BorderThickness="1" CornerRadius="12" Padding="8">
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="5">
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                          <TextBlock Text="Privacy &amp; Trust" FontSize="12" FontWeight="SemiBold" Foreground="#111827" />
                          <TextBlock Text="● Protected" FontSize="10" FontWeight="SemiBold" Foreground="#16A34A" />
                        </StackPanel>
                      </Grid>
                      <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
                        <CheckBox x:Name="AllowProviderContextToggle" Content="Provider" IsChecked="True" FontSize="10" Foreground="#374151" MinWidth="0" />
                        <CheckBox x:Name="SaveWorkThreadMemoryToggle" Grid.Column="1" Content="Memory" IsChecked="True" FontSize="10" Foreground="#374151" MinWidth="0" />
                        <CheckBox x:Name="ShowContextReceiptsToggle" Grid.Column="2" Content="Receipts" IsChecked="True" FontSize="10" Foreground="#374151" MinWidth="0" />
                        <CheckBox x:Name="ScreenshotVisionConsentToggle" Grid.Column="3" Content="Vision once" IsChecked="False" FontSize="10" Foreground="#7C2D12" MinWidth="0" />
                      </Grid>
                      <TextBlock Grid.Row="2" x:Name="ScreenshotVisionPolicyText" Text="Vision: off. Screenshot/OCR needs visible one-time approval." TextWrapping="WrapWholeWords" MaxLines="2" FontSize="10" Foreground="#6B7280" />
                    </Grid>
                  </Border>

                  <Border BorderBrush="#E5EDF8" BorderThickness="1" CornerRadius="12" Padding="8">
                    <StackPanel Spacing="6">
                      <TextBlock Text="Screenshot/OCR app policy" FontWeight="SemiBold" FontSize="11" Foreground="#111827" />
                      <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                        <Button Content="Allow Vision App" Click="AllowScreenshotVisionForSelectedApp_Click" Style="{StaticResource SidecarButtonStyle}" />
                        <Button Grid.Column="1" Content="Deny Vision App" Click="DenyScreenshotVisionForSelectedApp_Click" Style="{StaticResource WarmSidecarButtonStyle}" />
                      </Grid>
                      <Button Content="Ask Each Time" Click="ResetScreenshotVisionForSelectedApp_Click" Style="{StaticResource SidecarButtonStyle}" />
                    </StackPanel>
                  </Border>

                  <Border x:Name="DiagnosticsPanel" BorderThickness="1" BorderBrush="#E5EDF8" CornerRadius="8" Padding="6" Visibility="Collapsed">
                    <TextBlock x:Name="DiagnosticsText" Text="No diagnostics yet." TextWrapping="WrapWholeWords" FontSize="10" Foreground="#6B7280" />
                  </Border>

                  <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                    <Button Content="Diagnostics" Click="ToggleDiagnostics_Click" Style="{StaticResource SidecarButtonStyle}" />
                    <Button Content="Clear Context" Click="ClearSharedContext_Click" Style="{StaticResource SidecarButtonStyle}" />
                    <Button Content="Clear Chat" Click="ClearConversationAction_Click" Style="{StaticResource SidecarButtonStyle}" />
                    <Button Content="Clear Memory" Click="ClearMemoryAction_Click" Style="{StaticResource WarmSidecarButtonStyle}" />
                  </StackPanel>
                </StackPanel>
              </ScrollViewer>
            </Border>
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
