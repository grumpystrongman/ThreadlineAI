<Window x:Class="Threadline.Windows.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="ThreadlineAI">
  <Grid RowDefinitions="Auto,*" Padding="16">
    <StackPanel Orientation="Horizontal" Spacing="12">
      <TextBlock Text="ThreadlineAI" FontSize="22" FontWeight="SemiBold" />
      <Button Content="Start Session" Click="StartSession_Click" />
      <Button Content="Pause Capture" />
      <ComboBox Width="180" PlaceholderText="Provider">
        <ComboBoxItem Content="OpenAI" />
        <ComboBoxItem Content="Claude" />
        <ComboBoxItem Content="Gemini" />
        <ComboBoxItem Content="DeepSeek" />
        <ComboBoxItem Content="OpenRouter" />
        <ComboBoxItem Content="Local" />
      </ComboBox>
    </StackPanel>
    <Grid Grid.Row="1" ColumnDefinitions="2*,3*" ColumnSpacing="16" Margin="0,16,0,0">
      <StackPanel Spacing="12">
        <TextBlock Text="Current Context" FontSize="18" FontWeight="SemiBold" />
        <TextBlock x:Name="CurrentWindowText" Text="No active context yet." TextWrapping="Wrap" />
        <TextBlock Text="Timeline" FontSize="18" FontWeight="SemiBold" />
        <ListView x:Name="TimelineList" MinHeight="300" />
      </StackPanel>
      <Grid Grid.Column="1" RowDefinitions="*,Auto" RowSpacing="12">
        <ScrollViewer><TextBlock x:Name="ChatTranscript" Text="Ask Threadline about the current window or active session." TextWrapping="Wrap" /></ScrollViewer>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
          <TextBox x:Name="QuestionBox" PlaceholderText="Ask about this session..." MinWidth="480" />
          <Button Content="Ask" Click="Ask_Click" />
        </StackPanel>
      </Grid>
    </Grid>
  </Grid>
</Window>
